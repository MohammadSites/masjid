[
  {
    "text": "أفضلُكم من تعلَّم القرآن وعلَّمه.",
    "source": "البخاري"
  },
  {
    "text": "إنما الأعمالُ بالنيات.",
    "source": "متفق عليه"
  },
  {
    "text": "الدالُّ على الخير كفاعله.",
    "source": "الترمذي"
  },
  {
    "text": "من سلك طريقًا يلتمس فيه علمًا سهَّل الله له به طريقًا إلى الجنة.",
    "source": "مسلم"
  },
  {
    "text": "أحبُّ الأعمال إلى الله أدومها وإن قلَّ.",
    "source": "البخاري ومسلم"
  },
  {
    "text": "المسلمُ من سلم المسلمون من لسانه ويده.",
    "source": "البخاري ومسلم"
  },
  {
    "text": "تبسُّمك في وجه أخيك صدقة.",
    "source": "الترمذي"
  },
  {
    "text": "الراحمون يرحمهم الرحمن.",
    "source": "الترمذي"
  },
  {
    "text": "لا يؤمن أحدكم حتى يحب لأخيه ما يحب لنفسه.",
    "source": "البخاري ومسلم"
  },
  {
    "text": "من لا يشكر الناس لا يشكر الله.",
    "source": "الترمذي"
  }
]